{
  "mcu": "U1",

  "power": {
    "3V3": 3.3,
    "GND": 0.0
  },

  "parts": {
    "U1": {
      "type":  "esp32-wroom-32",
      "pins":  {
        "VDD":   "3V3",
        "GND_1": "GND",
        "IO2":   "LED_A",
        "IO4":   "BTN_SIG"
      }
    },

    "R1": {
      "type":  "resistor",
      "value": "220",
      "pins":  { "1": "LED_A", "2": "LED_K" }
    },

    "D1": {
      "type":     "led",
      "color":    "red",
      "vf":       2.0,
      "if_ma":    20,
      "series_r": 220,
      "pins":     { "A": "LED_K", "K": "GND" }
    },

    "SW1": {
      "type": "button",
      "pins": { "1": "BTN_SIG", "2": "GND" }
    }
  }
}
