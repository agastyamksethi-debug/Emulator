{
  "mcu": "U1",

  "power": {
    "3V3": 3.3,
    "GND": 0.0
  },

  "parts": {
    "U1": {
      "type": "esp32-wroom-32",
      "pins": {
        "VDD":   "3V3",
        "GND_1": "GND",
        "IO2":   "LED_A",
        "IO34":  "POT_W",
        "IO35":  "LDR_OUT"
      }
    },

    "POT1": {
      "type":     "potentiometer",
      "position": 0.5,
      "pins":     { "1": "3V3", "W": "POT_W", "2": "GND" }
    },

    "R1": {
      "type":  "resistor",
      "value": "220",
      "pins":  { "1": "LED_A", "2": "LED_K" }
    },

    "D1": {
      "type":     "led",
      "color":    "red",
      "vf":       2.0,
      "if_ma":    20,
      "series_r": 220,
      "pins":     { "A": "LED_K", "K": "GND" }
    },

    "LDR1": {
      "type":   "photoresistor",
      "pins":   { "1": "3V3", "2": "LDR_OUT" }
    }
  }
}
